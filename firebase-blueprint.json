{
  "entities": {
    "Order": {
      "title": "Order",
      "description": "Represents a customer purchase order",
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique purchase order ID"
        },
        "name": {
          "type": "string",
          "minLength": 2,
          "maxLength": 100,
          "description": "Customer Full Name"
        },
        "phone": {
          "type": "string",
          "minLength": 10,
          "maxLength": 20,
          "pattern": "^[0-9+\\-\\s]+$",
          "description": "Customer WhatsApp or Phone Number"
        },
        "productName": {
          "type": "string",
          "maxLength": 150,
          "description": "The name of the ordered product"
        },
        "totalPrice": {
          "type": "number",
          "description": "Total price of the order in Rs"
        },
        "address": {
          "type": "string",
          "minLength": 5,
          "maxLength": 500,
          "description": "Customer Full Shipping Address"
        },
        "city": {
          "type": "string",
          "maxLength": 100,
          "description": "Delivery City"
        },
        "gpsLink": {
          "type": "string",
          "maxLength": 500,
          "description": "Google Maps GPS location link"
        },
        "status": {
          "type": "string",
          "enum": ["Pending", "Shipped", "Delivered", "Cancelled"],
          "description": "Current order fulfillment state"
        },
        "createdAt": {
          "type": "string",
          "description": "Order creation date and time stamp"
        },
        "isWhatsApp": {
          "type": "boolean",
          "description": "Whether the order was placed or processed via WhatsApp"
        }
      },
      "required": ["id", "name", "phone", "productName", "totalPrice", "address", "city", "status", "createdAt"]
    }
  },
  "firestore": {
    "orders/{orderId}": {
      "schema": "Order",
      "description": "Collection of all placed orders"
    }
  }
}
